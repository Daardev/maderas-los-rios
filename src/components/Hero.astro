---
import IconTree from '../components/IconTree.astro';
import IconRecycle from '../components/IconRecycle.astro';
import ContactForm from './ContactForm.astro';
import Footer from '../components/Footer.astro';
---
<section class="relative min-h-screen overflow-hidden text-white" id="hero">
  <video class="absolute inset-0 w-full h-full object-cover" autoplay muted loop playsinline>
    <source src="/videos/hero-bg.mp4" type="video/mp4" />

    Tu navegador no soporta el video.
  </video>
  <div class="absolute inset-0 bg-black opacity-40"></div>
  <div class="relative z-10 flex min-h-screen flex-col px-4">
    <div class="mx-auto grid w-full max-w-7xl flex-1 grid-cols-1 items-center justify-center gap-8 pt-24 pb-12 md:grid-cols-2 md:py-0">
      <!-- Left column: title, tagline, icons -->
      <div class="space-y-6 text-center">
        <h1 class="text-4xl md:text-6xl font-bold">
          Maderas <span class="text-wood-600">Los Ríos</span>
        </h1>
        <p class="text-xl md:text-2xl">
          Calidad y experiencia en madera de secuoya. Desde el origen hasta tu proyecto, ofrecemos lo mejor en madera con precios directo desde el productor.
        </p>
        <div class="flex justify-center space-x-6 text-3xl">
          <IconTree />
          <IconRecycle />
        </div>
      </div>
      <!-- Right column: contact form -->
      <div class="flex justify-center">
        <ContactForm />
      </div>
    </div>
  </div>
    <Footer />
  </div>
</section>
