---
import IconTree from '../components/IconTree.astro';
import IconRecycle from '../components/IconRecycle.astro';
import ContactForm from './ContactForm.astro';
---
<section class="relative h-screen flex items-center justify-center text-white" id="hero">
  <video class="absolute inset-0 w-full h-full object-cover" autoplay muted loop playsinline>
    <source src="/src/assets/hero-bg.mp4" type="video/mp4" />
    <source src="/src/assets/hero-bg.webm" type="video/webm" />
    Tu navegador no soporta el video.
  </video>
  <div class="absolute inset-0 bg-black opacity-40"></div>
  <div class="relative z-10 max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
    <!-- Left column: title, tagline, icons -->
    <div class="space-y-6">
      <h1 class="text-4xl md:text-6xl font-bold">
        Maderas <span class="text-wood-600">Los Ríos</span>
      </h1>
      <p class="text-xl md:text-2xl">
        Calidad y experiencia en madera de secuoya.
      </p>
      <div class="flex space-x-6 text-3xl">
        <IconTree />
        <IconRecycle />
      </div>
    </div>
    <!-- Right column: contact form -->
    <ContactForm />
  </div>
</section>
